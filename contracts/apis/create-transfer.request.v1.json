{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ebank/contracts/apis/create-transfer.request.v1.json",
  "title": "CreateTransferRequest",
  "type": "object",
  "required": ["recipientPhone", "currency", "amountMinor"],
  "properties": {
    "recipientPhone": {
      "type": "string",
      "pattern": "^\\+[1-9][0-9]{7,14}$"
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "amountMinor": {
      "type": "integer",
      "minimum": 1
    },
    "note": {
      "type": "string",
      "maxLength": 140
    }
  },
  "additionalProperties": false
}
